{
  "name": "@b-health/telemetry",
  "version": "1.0.3",
  "description": "Telemetría B.Health: Logger de 4 verbos sobre Sentry (info/debug/report/throw) + reportPipeline, scope(), fireAndForget y guardia de ESLint",
  "repository": "github:b-health/telemetry",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    },
    "./eslint": "./eslint/index.mjs"
  },
  "files": [
    "dist",
    "eslint",
    "testing.js",
    "testing.d.ts"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "jest",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@sentry/node": ">=8 <11"
  },
  "devDependencies": {
    "@sentry/node": "^10.49.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
